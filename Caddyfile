# MENTORS dev-stand reverse proxy (spec 3/18).
# Automatic TLS: Caddy tries Let's Encrypt first, then ZeroSSL as a fallback
# (both ACME CAs are attempted by default). SITE_ADDRESS is injected from the
# environment (docker-compose caddy service) — currently the temporary sslip.io
# name; moving to a permanent domain = change SITE_ADDRESS + PLATFORM_URL + A record.
{$SITE_ADDRESS} {
	encode zstd gzip
	reverse_proxy web:3000
}

# Transitional 301 from the previous sslip.io name during the IP migration
# (ТСПУ-фильтрация старого адреса — см. changelog ТЗ). SITE_ADDRESS_OLD is injected
# from .env.prod / compose. Remove this block once the old IP is detached in the
# Beget panel and the old name is retired.
{$SITE_ADDRESS_OLD} {
	redir https://{$SITE_ADDRESS}{uri} permanent
}
