# MENTORS dev-stand — production env template (spec 18).
# The real file lives ONLY on the server at /opt/mentors/.env.prod and is never
# committed (see .gitignore). Compose reads it via `--env-file .env.prod` for
# both ${VAR} interpolation and the web container env.
#
# Values marked (generated) are created on the server during setup; values
# marked (you) are provided by the team. Never print the generated secrets.

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# --- PostgreSQL (compose interpolation + the postgres container) ---
POSTGRES_USER=mentors
POSTGRES_PASSWORD=          # (generated) URL-safe, matches DATABASE_URL below
POSTGRES_DB=mentors

# --- App runtime ---
# DATABASE_URL points at the compose service name `postgres`; password must
# equal POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://mentors:CHANGE_ME@postgres:5432/mentors?schema=public
SESSION_SECRET=            # (generated) >= 32 random chars
CRON_SECRET=              # (generated) >= 32 random chars
PLATFORM_URL=https://dev.62-113-108-135.sslip.io
BRAND_NAME=MENTORS
RENEWAL_CONTACT=          # (you) tg/mail link shown on /expired, blocked, reminders

# Caddy site address (temporary sslip.io name until a permanent domain).
SITE_ADDRESS=dev.62-113-108-135.sslip.io

# --- SMTP (stage 9; empty on the dev-stand — invite links shown in the UI) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- GeoIP (optional; empty = sessions.city stays null, no geo-flags) ---
GEOIP_DB_PATH=

# --- Dev-seed: owner + 2 mentors (spec 18 / seed.ts) ---
# Temp passwords are generated on the server; all three change them in profile
# after first login.
SEED_OWNER_EMAIL=         # (you)
SEED_OWNER_PASSWORD=      # (generated)
SEED_OWNER_NAME=Дима
SEED_MENTOR1_EMAIL=       # (you)
SEED_MENTOR1_PASSWORD=    # (generated)
SEED_MENTOR1_NAME=Егор
SEED_MENTOR2_EMAIL=       # (you)
SEED_MENTOR2_PASSWORD=    # (generated)
SEED_MENTOR2_NAME=Ментор
