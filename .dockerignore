# Keep the build context small and secrets out of the image.
.git
node_modules
.next
out
build
coverage
*.tsbuildinfo

# secrets — never enter the build context
.env
.env.local
.env*.local
.env.prod

# portable postgres (local dev only)
pgsql

# raw Notion export (importer input; runs locally over a tunnel, not in-image)
import
import-report.md

# local tooling / editor
.DS_Store
.claude
.vscode

# tests are not needed to build the image
tests
