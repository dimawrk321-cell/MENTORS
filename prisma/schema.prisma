// Stage 1 (spec section 17): auth & access models — users, invites, password
// resets, access extensions, sessions, devices, security flags + the service
// tables the stage needs (audit_log, analytics_events, app_settings) and the
// login rate-limit table required by spec section 11.
// Stage 2: content models — courses, modules, lessons, tracks, lesson_progress,
// content_reports.
// Stage 3: question bank & tests — question_categories, questions,
// question_lessons, module_tests, test_attempts, test_attempt_answers,
// quiz_answers + the content_reports.question_id FK.
// Stage 4: SRS — srs_cards, srs_reviews (spec 6 «SRS (повторения)»).
// Later stages append their own models incrementally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  mentor
  admin
  owner
}

enum UserStatus {
  invited
  active
  blocked
  expired
}

enum Theme {
  system
  dark
  light
}

enum Track {
  ds
  nlp
  ai
}

enum SessionRevokeReason {
  evicted_login // single concurrent session: a newer login displaced this one
  evicted_device // device cap: the oldest device was displaced by a third one
  logout
  logout_all
  password_change
  password_reset
  admin_reset
  blocked
  impersonation_end
}

enum SecurityFlagType {
  concurrent_geo
  rapid_content
  manual
}

enum SecurityFlagStatus {
  open
  resolved
}

enum AuthAttemptKind {
  login
  forgot
}

model User {
  id     String     @id @default(cuid())
  email  String     @unique
  // DECISION: spec 6 lists password_hash as required, but an invited user has
  // no password until the invite is accepted — nullable expresses that state.
  passwordHash  String?    @map("password_hash")
  name          String
  role          Role       @default(student)
  isInterviewer Boolean    @default(false) @map("is_interviewer")
  timezone      String     @default("Europe/Moscow")
  theme         Theme      @default(system)
  track         Track?
  dailyGoalXp   Int        @default(60) @map("daily_goal_xp")
  studyDays     Int[]      @default([1, 2, 3, 4, 5, 6, 7]) @map("study_days")
  digestTime    String     @default("09:00") @map("digest_time")
  status        UserStatus @default(invited)
  activatedAt   DateTime?  @map("activated_at")
  accessUntil   DateTime?  @map("access_until")
  // DECISION: avatar_color has no type in spec 6 — stored as an index (0..7)
  // into the muted category palette (spec 5.1), assigned from email hash.
  avatarColor    Int       @map("avatar_color")
  lastSeenAt     DateTime? @map("last_seen_at")
  mentorNote     String?   @map("mentor_note")
  libraryEnabled Boolean   @default(true) @map("library_enabled")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sessions             Session[]         @relation("UserSessions")
  impersonatedSessions Session[]         @relation("SessionImpersonator")
  devices              Device[]
  invitesSent          Invite[]          @relation("InviteInvitedBy")
  passwordResets       PasswordReset[]
  accessExtensions     AccessExtension[] @relation("ExtensionUser")
  grantedExtensions    AccessExtension[] @relation("ExtensionGrantedBy")
  securityFlags        SecurityFlag[]    @relation("FlagUser")
  resolvedFlags        SecurityFlag[]    @relation("FlagResolvedBy")
  auditEntries         AuditLog[]        @relation("AuditActor")
  analyticsEvents      AnalyticsEvent[]
  lessonProgress       LessonProgress[]
  contentReports       ContentReport[]   @relation("ReportAuthor")
  resolvedReports      ContentReport[]   @relation("ReportResolvedBy")
  testAttempts         TestAttempt[]
  quizAnswers          QuizAnswer[]
  srsCards             SrsCard[]
  xpEvents             XpEvent[]
  streak               Streak?
  streakEvents         StreakEvent[]
  userAchievements     UserAchievement[]

  @@index([status, accessUntil])
  @@map("users")
}

model Invite {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  invitedById String    @map("invited_by")
  invitedBy   User      @relation("InviteInvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@index([invitedById])
  @@map("invites")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("password_resets")
}

model AccessExtension {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation("ExtensionUser", fields: [userId], references: [id], onDelete: Cascade)
  days           Int
  newAccessUntil DateTime @map("new_access_until")
  grantedById    String   @map("granted_by")
  grantedBy      User     @relation("ExtensionGrantedBy", fields: [grantedById], references: [id])
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([grantedById])
  @@map("access_extensions")
}

model Session {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  user      User    @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String  @unique @map("token_hash")
  // DECISION: nullable — impersonation sessions belong to the admin's browser
  // and must not occupy one of the student's two device slots. SetNull (not
  // Cascade): deleting an evicted device must keep revoked session rows so the
  // displaced browser can still render the eviction screen.
  deviceId  String? @map("device_id")
  device    Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  ip        String
  city      String?
  country   String?
  expiresAt      DateTime  @map("expires_at")
  lastActiveAt   DateTime  @default(now()) @map("last_active_at")
  impersonatorId String?   @map("impersonator_id")
  impersonator   User?     @relation("SessionImpersonator", fields: [impersonatorId], references: [id], onDelete: Cascade)
  // DECISION: evicted sessions are kept (revoked_at + reason) instead of being
  // deleted so the displaced request can render the dedicated «Вход выполнен на
  // другом устройстве» screen (spec 7.2); sessionCleanup purges them at stage 9.
  revokedAt     DateTime?            @map("revoked_at")
  revokedReason SessionRevokeReason? @map("revoked_reason")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([userId])
  @@index([deviceId])
  @@index([impersonatorId])
  @@index([expiresAt])
  @@map("sessions")
}

model Device {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprintHash String    @map("fingerprint_hash")
  label           String
  firstSeenAt     DateTime  @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  sessions        Session[]

  @@unique([userId, fingerprintHash])
  @@map("devices")
}

model SecurityFlag {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  user         User               @relation("FlagUser", fields: [userId], references: [id], onDelete: Cascade)
  type         SecurityFlagType
  details      Json
  status       SecurityFlagStatus @default(open)
  resolvedById String?            @map("resolved_by")
  resolvedBy   User?              @relation("FlagResolvedBy", fields: [resolvedById], references: [id])
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@index([userId, type, createdAt])
  @@index([status])
  @@index([resolvedById])
  @@map("security_flags")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String   @map("actor_id")
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_log")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type      String
  payload   Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

// DECISION: spec 11 requires a table for failed login attempts (restart-safe
// rate limit); forgot-password requests share it via `kind`. Append-only, no
// updated_at; old rows are pruned opportunistically by the rate limiter.
model AuthAttempt {
  id        String          @id @default(cuid())
  kind      AuthAttemptKind
  email     String
  ip        String
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([kind, email, ip, createdAt])
  @@map("auth_attempts")
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// --- Stage 2: content (spec 6 «Контент») ---

enum CourseGating {
  strict
  recommended
  free
}

enum ContentStatus {
  draft
  published
}

enum LessonDifficulty {
  intro
  base
  advanced
}

enum VideoStatus {
  ok
  unavailable
  unchecked
}

enum LessonProgressStatus {
  in_progress
  completed
}

enum ContentReportType {
  error
  unclear
}

enum ContentReportStatus {
  open
  resolved
}

model Course {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String        @default("")
  order       Int           @default(0)
  gating      CourseGating  @default(strict)
  status      ContentStatus @default(draft)
  icon        String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  modules     Module[]

  @@map("courses")
}

model Module {
  id        String        @id @default(cuid())
  courseId  String        @map("course_id")
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title     String
  order     Int           @default(0)
  status    ContentStatus @default(draft)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  lessons   Lesson[]
  test      ModuleTest?
  attempts  TestAttempt[]

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id         String        @id @default(cuid())
  moduleId   String        @map("module_id")
  module     Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  // DECISION: spec 6 does not scope lesson slug uniqueness; routes are id-based
  // (/lessons/[id]), so the slug is unique per module — enough for anchors/import.
  slug       String
  title      String
  order      Int           @default(0)
  status     ContentStatus @default(draft)
  difficulty LessonDifficulty @default(base)
  isOptional Boolean       @default(false) @map("is_optional")
  contentMd  String        @default("") @map("content_md")
  // Recomputed on save: words / 180 (spec 6).
  readingMinutes   Int         @default(1) @map("reading_minutes")
  videoUrl         String?     @map("video_url")
  videoStatus      VideoStatus @default(unchecked) @map("video_status")
  videoCheckedAt   DateTime?   @map("video_checked_at")
  publishedAt      DateTime?   @map("published_at")
  // Bumped only when content_md changes — powers the «урок обновлён» badge.
  contentUpdatedAt DateTime    @default(now()) @map("content_updated_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  progress         LessonProgress[]
  reports          ContentReport[]
  questionLinks    QuestionLesson[]
  quizAnswers      QuizAnswer[]

  @@unique([moduleId, slug])
  @@index([moduleId])
  @@map("lessons")
}

model TrackDef {
  id        String   @id @default(cuid())
  key       Track    @unique
  title     String
  // Ordered list of course ids (spec 6: course_ids:json).
  courseIds Json     @map("course_ids")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tracks")
}

model LessonProgress {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String               @map("lesson_id")
  lesson      Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  status      LessonProgressStatus @default(in_progress)
  completedAt DateTime?            @map("completed_at")
  scrollPos   Float?               @map("scroll_pos")
  videoPos    Int?                 @map("video_pos")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@unique([userId, lessonId])
  @@index([lessonId])
  @@map("lesson_progress")
}

// --- Stage 3: question bank & tests (spec 6 «Вопросы и тесты») ---

enum QuestionType {
  open
  single
  multi
  tf
  short_text
}

enum QuestionSource {
  import
  manual
}

enum TestKind {
  module
  testout
}

model QuestionCategory {
  id         String             @id @default(cuid())
  title      String
  slug       String             @unique
  parentId   String?            @map("parent_id")
  parent     QuestionCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   QuestionCategory[] @relation("CategoryTree")
  // Spec 5.1/7.4: 8 muted pairs assigned to root categories in order.
  colorIndex Int                @map("color_index")
  order      Int                @default(0)
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  questions  Question[]

  @@index([parentId])
  @@map("question_categories")
}

model Question {
  id            String           @id @default(cuid())
  type          QuestionType
  categoryId    String           @map("category_id")
  category      QuestionCategory @relation(fields: [categoryId], references: [id])
  textMd        String           @map("text_md")
  /** Эталон открытого вопроса (может содержать изображения/KaTeX). */
  answerMd      String?          @map("answer_md")
  /** Разбор закрытого вопроса — показывается в квизе и успешном тесте. */
  explanationMd String?          @map("explanation_md")
  /** [{id,text,correct}] для single|multi|tf. */
  options       Json?
  /** string[] для short_text (сравнение через нормализацию 7.4). */
  acceptedAnswers Json?          @map("accepted_answers")
  difficulty    Int              @default(2)
  status        ContentStatus    @default(draft)
  /** Флаг импортера: ответ был картинкой, формулы надо переписать в KaTeX. */
  needsLatex    Boolean          @default(false) @map("needs_latex")
  source        QuestionSource   @default(manual)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  lessonLinks    QuestionLesson[]
  quizAnswers    QuizAnswer[]
  attemptAnswers TestAttemptAnswer[]
  reports        ContentReport[]
  srsCards       SrsCard[]

  @@index([categoryId])
  @@index([status, type])
  @@map("questions")
}

model QuestionLesson {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  lessonId   String   @map("lesson_id")
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  /** Ключевой вопрос урока → в SRS при завершении (этап 4). */
  isKey  Boolean @default(false) @map("is_key")
  /** Участвует в квизе урока. */
  inQuiz Boolean @default(false) @map("in_quiz")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([questionId, lessonId])
  @@index([lessonId])
  @@map("question_lessons")
}

model ModuleTest {
  id              String   @id @default(cuid())
  moduleId        String   @unique @map("module_id")
  module          Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  poolSize        Int      @default(12) @map("pool_size")
  threshold       Int      @default(80)
  cooldownMinutes Int      @default(45) @map("cooldown_minutes")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("module_tests")
}

model TestAttempt {
  id       String   @id @default(cuid())
  userId   String   @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId String   @map("module_id")
  module   Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  kind     TestKind @default(module)
  /** Зафиксированная выборка вопросов (string[] в порядке показа). */
  questionIds Json      @map("question_ids")
  score       Int       @default(0)
  passed      Boolean   @default(false)
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  answers     TestAttemptAnswer[]

  @@index([userId, moduleId, kind])
  @@map("test_attempts")
}

model TestAttemptAnswer {
  id         String      @id @default(cuid())
  attemptId  String      @map("attempt_id")
  attempt    TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String      @map("question_id")
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     Json
  correct    Boolean
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@map("test_attempt_answers")
}

model QuizAnswer {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  lessonId   String   @map("lesson_id")
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  correct    Boolean
  /** Первый правильный ответ на вопрос — для разовой выдачи XP (этап 5). */
  first     Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, questionId])
  @@index([lessonId])
  @@map("quiz_answers")
}

// --- Stage 4: SRS (spec 6 «SRS (повторения)», логика — spec 7.6) ---

enum SrsGrade {
  again
  hard
  good
}

// DECISION: spec 6 lists lesson_key|test_fail|quiz_fail|mock, but spec 7.4
// explicitly allows manual additions with added_from=manual — the enum carries
// all five. `mock` is reserved until stage 6 wires the interviewer marks.
enum SrsAddedFrom {
  lesson_key
  test_fail
  quiz_fail
  mock
  manual
}

model SrsCard {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  /** 0–4 — лестница STEPS, 5 — «выучен» (контрольный показ раз в 90 дней). */
  step Int @default(0)
  /** Календарная дата в TZ пользователя, хранится как date (полночь UTC). */
  nextReviewAt DateTime     @map("next_review_at") @db.Date
  addedFrom    SrsAddedFrom @map("added_from")
  /** Считает только оценку «Не знаю» — сбросы источников его не трогают. */
  lapses       Int       @default(0)
  reviewsCount Int       @default(0) @map("reviews_count")
  lastGrade    SrsGrade? @map("last_grade")
  suspended    Boolean   @default(false)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  reviews      SrsReview[]

  @@unique([userId, questionId])
  // Spec 12: составной индекс под выборку дневной очереди.
  @@index([userId, nextReviewAt])
  @@index([questionId])
  @@map("srs_cards")
}

model SrsReview {
  id         String   @id @default(cuid())
  cardId     String   @map("card_id")
  card       SrsCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  grade      SrsGrade
  reviewedAt DateTime @default(now()) @map("reviewed_at")
  prevStep   Int      @map("prev_step")
  newStep    Int      @map("new_step")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([cardId, reviewedAt])
  @@map("srs_reviews")
}

model ContentReport {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  user     User    @relation("ReportAuthor", fields: [userId], references: [id], onDelete: Cascade)
  lessonId String? @map("lesson_id")
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  questionId   String?             @map("question_id")
  question     Question?           @relation(fields: [questionId], references: [id], onDelete: SetNull)
  blockAnchor  String?             @map("block_anchor")
  type         ContentReportType
  text         String?
  status       ContentReportStatus @default(open)
  resolvedById String?             @map("resolved_by")
  resolvedBy   User?               @relation("ReportResolvedBy", fields: [resolvedById], references: [id])
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@index([userId])
  @@index([lessonId])
  @@index([status])
  @@map("content_reports")
}

// --- Stage 5: gamification (spec 6 «Геймификация», логика — spec 7.7/7.13) ---

// Единая идемпотентная запись начисления XP. Диспетчер событий (7.13) — единственный
// писатель; уникальный индекс (user, type, ref) — барьер exactly-once (в т.ч. для
// queue.completed из двух вкладок). Все XP-начисления несут непустой ref (гарантия кода).
model XpEvent {
  id      String  @id @default(cuid())
  userId  String  @map("user_id")
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String
  amount  Int
  refType String? @map("ref_type")
  refId   String? @map("ref_id")
  /** Календарная дата начисления в TZ пользователя (полночь UTC, @db.Date). */
  day       DateTime @map("day") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  // Идемпотентность (spec 6/7.7): одно начисление на (user, type, ref_type, ref_id).
  @@unique([userId, type, refType, refId])
  // Spec 12: составной индекс под дневную сумму (кольцо цели).
  @@index([userId, day])
  @@map("xp_events")
}

model Streak {
  id      String @id @default(cuid())
  userId  String @unique @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  current Int    @default(0)
  best    Int    @default(0)
  /** Заморозки 0–2: +1 за каждые 7 подряд засчитанных дней (spec 7.7). */
  freezes         Int       @default(0)
  lastCountedDate DateTime? @map("last_counted_date") @db.Date
  /** true при истёкшем доступе (spec 7.1.5): дни не считаются вовсе. */
  paused    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("streaks")
}

enum StreakEventKind {
  counted
  freeze_used
  reset
  milestone
}

model StreakEvent {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime        @db.Date
  kind      StreakEventKind
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([userId, date])
  @@map("streak_events")
}

// Справочник достижений (spec 7.7): сидится из кода (ACHIEVEMENTS). Приложение
// читает определения из константы; таблица — зеркало для БД/будущей админки.
model Achievement {
  key         String   @id
  title       String
  description String
  hidden      Boolean  @default(false)
  icon        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("achievements")
}

model UserAchievement {
  id     String @id @default(cuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  // DECISION: plain string, no FK to achievements — granting must not depend on
  // the dictionary being seeded (keeps the event dispatcher robust); definitions
  // (title/icon/hidden) live in the ACHIEVEMENTS code constant, the table mirrors it.
  achievementKey String   @map("achievement_key")
  earnedAt       DateTime @default(now()) @map("earned_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([userId, achievementKey])
  @@index([userId])
  @@map("user_achievements")
}
