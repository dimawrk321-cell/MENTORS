# DECISION: full env list from section 18 is documented from stage 0;
# at stage 0 only DATABASE_URL and BRAND_NAME are actually read by the code.

# Раздел 0.7 ТЗ: никакой телеметрии наружу (отключает телеметрию Next.js)
NEXT_TELEMETRY_DISABLED=1

# PostgreSQL (docker-compose.dev.yml поднимает базу с этими реквизитами)
DATABASE_URL=postgresql://mentors:mentors@localhost:5432/mentors

# Криптосекреты (сгенерируйте случайные строки >= 32 символов)
SESSION_SECRET=change-me
CRON_SECRET=change-me

# Платформа
PLATFORM_URL=http://localhost:3000
BRAND_NAME=MENTORS

# SMTP (этап 9)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Контакт для продления доступа (ссылка tg/mail)
RENEWAL_CONTACT=

# GeoIP (этап 1, опционально)
GEOIP_DB_PATH=

# Dev-seed (этап 1): owner + 2 ментора (SEED_*_NAME опциональны).
# Полный сид контента — этап 13.
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=
SEED_MENTOR1_EMAIL=
SEED_MENTOR1_PASSWORD=
SEED_MENTOR1_NAME=
SEED_MENTOR2_EMAIL=
SEED_MENTOR2_PASSWORD=
SEED_MENTOR2_NAME=

NODE_ENV=development
